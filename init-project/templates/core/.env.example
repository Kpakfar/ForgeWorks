# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Document every variable here with an empty or example value -- no real secrets.

# --- Examples (uncomment and set the ones this project actually uses) ---
# LLM provider API key (e.g. OpenAI, Anthropic, OpenRouter)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Database connection string
# DATABASE_URL=

# Backend bearer token (if the API auth gate is enabled; see docs/SECURITY.md)
# RADAR_API_TOKEN=
