# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Document every variable here with an empty or example value -- no real secrets.

# Add only the variables this project actually uses; delete the rest.
# Examples:
# DATABASE_URL=
# API_AUTH_TOKEN=        # if the project exposes an authenticated API (see docs/SECURITY.md)
# <PROVIDER>_API_KEY=    # if the project calls an external/LLM API
