# Rust
# Build output
/target/

# rustfmt backup files
**/*.rs.bk

# Debug symbols (MSVC)
*.pdb

# NOTE: Cargo.lock is COMMITTED (reproducible builds for applications and
# libraries alike) -- do not add it here.

# Environment
.env
.env.local
.env.*.local
*.local

# IDE
.vscode/*
!.vscode/settings.json.example
.idea/
*.swp
*.swo
.DS_Store

# Claude / agent state
.claude/cache/
.claude/state/
.claude/skills/_user-data/

# Logs
*.log
logs/

# Project-specific
docs/_log/             # archived task logs (move to git history instead)
docs/_init-answers.md  # temp file from init-project skill
